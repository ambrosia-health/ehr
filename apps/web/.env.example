# Server-only Modal/FastAPI origin used by the Next.js same-origin rewrite.
AMBROSIA_API_ORIGIN=https://your-modal-api.example

# Canonical public URL for metadata, smoke tests, and deployment tooling.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local/CI live E2E only. Keep the credential in secret storage.
E2E_LIVE_API=0
PRESENTER_ACCESS_CODE=
