# Ambrosia local development defaults. Copy to .env; never commit real values.
# This repository and its canonical seed are synthetic-data-only.

# Runtime
APP_ENV=development
EXECUTION_PLATFORM=local
DEMO_MODE=true
ALLOW_SYNTHETIC_DEMO_RESET=true
# Pytest ignores configured databases unless an explicit local Postgres test target overrides this.
ALLOW_TEST_DATABASE_RESET=false
AUTO_CREATE_SCHEMA=false
AUTO_SEED=false

# Browser / Vercel. Keep the API origin server-only: the browser calls same-origin /api.
# Keep demo test mode false for integrated E2E; it is only for isolated API harnesses.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_TEST_MODE=false
AMBROSIA_API_ORIGIN=http://127.0.0.1:8000

# Published values are for the disposable local synthetic demo only.
# Generate distinct shared/hosted values with: openssl rand -hex 32
AUTH_SESSION_SECRET=ambrosia-local-synthetic-session-secret-change-for-shared-use
DEMO_PRESENTER_SECRET=ambrosia-demo
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Local zero-credential default. Hosted environments must use a Neon pooled URL with TLS.
DATABASE_URL=sqlite+aiosqlite:///./.ambrosia/ambrosia.db

# Optional Docker Postgres fidelity target (`make dev-postgres`).
POSTGRES_DB=ambrosia
POSTGRES_USER=ambrosia
POSTGRES_PASSWORD=ambrosia-local-only
POSTGRES_PORT=5432
POSTGRES_DATABASE_URL=postgresql+asyncpg://ambrosia:ambrosia-local-only@127.0.0.1:5432/ambrosia

# AI execution. Local development uses the deterministic fallback. Managed hosted runtimes
# inject OPENAI_API_KEY through Modal Secrets; never copy it into this file.
AI_REQUEST_TIMEOUT_SECONDS=20

# Reserved integration selectors. The demo supports only these simulated values;
# they write normal domain records through provider interfaces.
ELIGIBILITY_PROVIDER=simulated
CLEARINGHOUSE_PROVIDER=simulated
REMITTANCE_PROVIDER=simulated
MESSAGING_PROVIDER=simulated
EPRESCRIBING_PROVIDER=simulated
PATHOLOGY_PROVIDER=simulated
PAYMENT_PROVIDER=simulated

# Optional Vercel-managed private synthetic uploads.
BLOB_READ_WRITE_TOKEN=

# Modal CLI/deployment credentials. Prefer Modal environment secrets at runtime.
MODAL_ENVIRONMENT=dev
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Vercel deploys through the repository's native Git integration. Contributors do not
# need a Vercel token or any per-clone Vercel configuration.

# Protected Modal deployment/migration smoke inputs; configure as GitHub environment secrets.
NEON_DATABASE_URL_DIRECT=
MODAL_API_HEALTH_URL=

# Use Vercel, Modal, and Neon-native operational telemetry for the demo.
# Do not emit note text, messages, images, or raw AI context.
